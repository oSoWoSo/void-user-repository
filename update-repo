#!/bin/sh
#
# Manage repository: templates, README, build.yml, website, and packages.
# Merged from update-repo + create-web.
#
# Author: zenobit <zenobit@disroot.org>
# License: GPL-3.0-only

[ -f .env ] && . .env

SRCPKGS='srcpkgs'
TEMPLATES_LIST='.github/templatesList'
README='README.md'
WORKFLOW='.github/workflows/build.yml'
BUILD_START='.github/build-START.yml'
BUILD_REST='.github/build-REST.yml'

SURFER_URL="https://repo.osowoso.org"
SIGNED_BY="zenobit <zenobit@disroot.org>"
SCRIPT_DIR=$(cd -- "$(dirname -- "$0")" && pwd)
ARCHES='x86_64 x86_64-musl aarch64 aarch64-musl'

# --- UI helpers (ANSI) ---

if [ -z "$NO_COLOR" ]; then
	RED=$(printf '\033[0;31m')
	GREEN=$(printf '\033[0;32m')
	YELLOW=$(printf '\033[1;33m')
	BLUE=$(printf '\033[0;34m')
	NC=$(printf '\033[0m')
fi
_r()  { echo "${RED}${1}${NC}"; }
_re() { echo "${RED}${1}${NC}" >&2; exit 1; }
_g()  { echo "${GREEN}${1}${NC}"; }
_b()  { echo "${BLUE}${1}${NC}"; }
_y()  { echo "${YELLOW}${1}${NC}"; }
ask() {
	_y "Press Enter to continue (Ctrl+C to quit)..."
	echo "$1"
	read -r _key || true
}

# --- Core helpers ---

fatal() {
	echo '[FATAL]' "$@" >&2
	exit 1
}

usage() {
	prog=${0##*/}
	cat <<-EOF
	Usage: $prog -h | -u | -w | -p | -s | -a
	       $prog {update|build|upload|serve|archs|help}

	Manage repository: templates, README, build.yml, website, and packages.

	Options
	  -u, --update     update list, README, and build.yml
	  -w, --build      regenerate website (requires pandoc)
	  -p, --upload     upload built packages to WebDAV repository
	  -s, --serve      serve website locally on port 8000
	  -a, --archs      regenerate architecture pages only
	  -h, --help       print this message

	Compound: $prog -uw   (update + build)
	EOF
}

# --- Package helpers ---

pkg_name() {
	_without_arch="${1%.*}"
	_ver=$(printf '%s' "$_without_arch" | sed 's/^.*-\([0-9][^-]*\)$/\1/')
	printf '%s' "${_without_arch%-${_ver}}"
}

pkg_arch_ok() {
	_pkg="$1" _target="$2"
	_tpl="${SRCPKGS}/${_pkg}/template"
	[ -f "$_tpl" ] || return 0
	_archs=$(grep -m1 '^archs=' "$_tpl" | sed 's/^archs=//;s/"//g')
	[ -z "$_archs" ] && return 0
	_last=''
	for _pat in $_archs; do
		_last="$_pat"
		case "$_target" in
			${_pat#~}) case "$_pat" in ~*) return 1 ;; *) return 0 ;; esac ;;
		esac
	done
	case "$_last" in ~*) return 0 ;; esac
	return 1
}

fetch_remote_list() {
	curl -s -X PROPFIND "${1}/" \
		-H 'Depth: 1' \
		-u ":${SURFER_TOKEN}" 2>/dev/null \
		| grep -o '<D:href>[^<]*\.xbps</D:href>' \
		| sed 's|<D:href>||;s|</D:href>||;s|.*/||' || true
}

delete_remote() {
	curl -s -X DELETE "${1}" -u ":${SURFER_TOKEN}" || true
}

upload_file() {
	_file="$1" _dest="$2"
	echo "  Uploading: $(basename "$_file")"
	curl -s -T "$_file" "$_dest" -u ":${SURFER_TOKEN}" \
		|| echo "  Warning: failed to upload $(basename "$_file")"
}

prune_orphans() {
	echo '==> Pruning orphan packages (no template in srcpkgs)'
	for _remote_pkg in $_remote_list; do
		_pkg=$(pkg_name "${_remote_pkg%.xbps}")
		[ -d "${SRCPKGS}/${_pkg}" ] && continue
		echo "  Removing orphan: $_remote_pkg"
		if curl -sf -o "$_remote_pkg" "${SURFER_URL}/${ARCH}/${_remote_pkg}" \
				-u ":${SURFER_TOKEN}" 2>/dev/null; then
			xbps-rindex -r . "$_remote_pkg" || true
			rm -f "$_remote_pkg" "${_remote_pkg}.sig2"
		fi
		delete_remote "${_webdav}/${_remote_pkg}"
		delete_remote "${_webdav}/${_remote_pkg}.sig2"
	done
}

# --- Website helpers (from create-web) ---

_build_main_index() {
	_title="${1:-Void Community Repository}"

	_nav_arch_tmp=$(mktemp)
	_readme_tmp=$(mktemp)
	_svg_tmp=$(mktemp)

	for _arch in $ARCHES; do
		printf '  <li><a href="%s/">%s</a></li>\n' "$_arch" "$_arch" >> "$_nav_arch_tmp"
	done
	printf '  <li><a href="https://codeberg.org/osowoso/oco">&#x2934; source</a></li>\n' >> "$_nav_arch_tmp"
	if [ -n "${REPO_URL:-}" ]; then
		printf '  <li><a href="%s">CI</a></li>\n' "$REPO_URL" >> "$_nav_arch_tmp"
	fi

	pandoc README.md -f gfm > "$_readme_tmp"
	cp src/svg-color.html "$_svg_tmp"

	sed \
		-e "s|__CSS_URL__|style.css|g" \
		-e 's|__FAVICON__|<link rel="icon" href="favicon.ico" />|g' \
		.github/main-index-template.html \
	| awk \
		-v nav_arch="$_nav_arch_tmp" \
		-v readme="$_readme_tmp" \
		-v svg="$_svg_tmp" \
		'/__NAV_ARCH_LINKS__/ { while ((getline ln < nav_arch) > 0) print ln; close(nav_arch); next }
		 /__README_CONTENT__/  { while ((getline ln < readme)   > 0) print ln; close(readme);   next }
		 /__SVGCOLOR__/        { while ((getline ln < svg)      > 0) print ln; close(svg);       next }
		 { print }' \
	> "docs/index.html"

	rm -f "$_nav_arch_tmp" "$_readme_tmp" "$_svg_tmp"
	_g "Generated: docs/index.html"
}

# --- Update ---

generate_list() {
	new_list=$(for _entry in "$SRCPKGS"/*/; do
		[ -d "$_entry" ] || [ -L "$_entry" ] || continue
		_pkg=${_entry%/}
		_pkg=${_pkg##*/}
		echo "$_pkg"
	done | sort -f)

	mkdir -p "$(dirname "$TEMPLATES_LIST")"
	if [ -f "$TEMPLATES_LIST" ] && [ "$new_list" = "$(cat "$TEMPLATES_LIST")" ]; then
		echo 'templatesList: no changes'
	else
		echo "$new_list" > "$TEMPLATES_LIST"
		echo 'templatesList: updated'
	fi
}

generate_readme() {
	_tmp=$(mktemp)

	awk '/^## Available/{exit} {print}' "$README" > "$_tmp"

	{
		echo '## Available templates (packages when built successfully)'
		echo '| package | version | homepage | maintainer | notes |'
		echo '|:--------|:--------|:---------|:-----------|:------|'
		while IFS= read -r _pkg; do
			_tpl="$SRCPKGS/$_pkg/template"
			[ -f "$_tpl" ] || continue
			_homepage=$(grep '^homepage='    "$_tpl" | head -n 1 | cut -d= -f2- | tr -d '"')
			_version=$(grep  '^version='     "$_tpl" | head -n 1 | cut -d= -f2- | tr -d '"')
			_maintainer=$(grep '^maintainer=' "$_tpl" | head -n 1 | cut -d= -f2- | sed 's/ <.*//' | tr -d '"')
			_notes=$(grep    '^archs='       "$_tpl" | head -n 1 | cut -d= -f2- | tr -d '"')
			echo "| $_pkg | $_version | $_homepage | $_maintainer | $_notes |"
		done < "$TEMPLATES_LIST"
	} >> "$_tmp"

	mv "$_tmp" "$README"
	echo "README: updated"
}

generate_build_yml() {
	[ -f "$BUILD_START" ]   || fatal "not found: ${BUILD_START}"
	[ -f "$BUILD_REST" ]    || fatal "not found: ${BUILD_REST}"
	[ -f "$TEMPLATES_LIST" ] || fatal "not found: ${TEMPLATES_LIST}"

	mkdir -p "$(dirname "$WORKFLOW")"
	cat "$BUILD_START" > "$WORKFLOW"
	while IFS= read -r _pkg; do
		[ -z "$_pkg" ] && continue
		echo "        - $_pkg"
	done < "$TEMPLATES_LIST" >> "$WORKFLOW"
	cat "$BUILD_REST" >> "$WORKFLOW"

	echo "build.yml: updated"
}

detect_changes() {
	if ! git rev-parse HEAD~1 >/dev/null 2>&1; then
		echo '==> First commit'
		_added=$(cat "$TEMPLATES_LIST")
		_modified=''
		_removed=''
	else
		_diff=$(git diff --name-status HEAD~1 HEAD -- "$SRCPKGS")
		_added=$(   echo "$_diff" | awk '$1=="A"{print $2}' | cut -d/ -f2 | sort -u)
		_modified=$(echo "$_diff" | awk '$1=="M"{print $2}' | cut -d/ -f2 | sort -u)
		_removed=$( echo "$_diff" | awk '$1=="D"{print $2}' | cut -d/ -f2 | sort -u)
	fi

	_added=$(echo "$_added"     | sed '/^$/d')
	_modified=$(echo "$_modified" | sed '/^$/d')
	_removed=$(echo "$_removed"   | sed '/^$/d')

	echo "==> Added:   $(echo "$_added" | tr '\n' ' ')"
	echo "==> Modified: $(echo "$_modified" | tr '\n' ' ')"
	echo "==> Removed: $(echo "$_removed" | tr '\n' ' ')"
}

# --- Web ---

build_site() {
	_title="${1:-Void Community Repository}"

	if ! command -v pandoc >/dev/null 2>&1; then
		echo "pandoc: not installed, skipping website"
		return
	fi

	if [ -f docs/CNAME ]; then
		cp docs/CNAME src/
	fi
	rm -rf docs && mkdir -p docs
	cp -r src/* docs/
	rm -f docs/toggle.html docs/toc.html docs/svg-color.html docs/footer.html

	_build_main_index "$_title"
	generate_arch_pages
	_g "Finished"
}

generate_arch_pages() {
	_template="${SCRIPT_DIR}/.github/arch-index-template.html"
	[ -f "$_template" ] || { echo "arch-index-template.html not found, skipping arch pages"; return 1; }

	_pkg_list=$(for _entry in "$SRCPKGS"/*/; do
		[ -d "$_entry" ] || [ -L "$_entry" ] || continue
		_p=${_entry%/}; _p=${_p##*/}; echo "$_p"
	done | sort -f)

	for _arch in $ARCHES; do
		_out_dir="${SCRIPT_DIR}/docs/${_arch}"
		_out="${_out_dir}/index.html"
		_repo_url="${SURFER_URL}/${_arch}"

		mkdir -p "$_out_dir"

		_nav_tmp=$(mktemp)
		_pkg_tmp=$(mktemp)
		_svg_tmp=$(mktemp)

		for _a in $ARCHES; do
			if [ "$_a" = "$_arch" ]; then
				printf '  <li><a href="." class="active">%s</a></li>\n' "$_arch" >> "$_nav_tmp"
			else
				printf '  <li><a href="../%s/">%s</a></li>\n' "$_a" "$_a" >> "$_nav_tmp"
			fi
		done

		{
			printf '<table>\n<thead><tr>\n'
			printf '  <th>package</th><th>version</th><th>homepage</th><th>maintainer</th><th>description</th>\n'
			printf '</tr></thead>\n<tbody>\n'

			_pkg_count=0
			for _pkg in $_pkg_list; do
				pkg_arch_ok "$_pkg" "$_arch" || continue
				_tpl="${SRCPKGS}/${_pkg}/template"
				[ -f "$_tpl" ] || continue

				_version=$(grep '^version='    "$_tpl" | head -n 1 | cut -d= -f2- | tr -d '"')
				_homepage=$(grep '^homepage='   "$_tpl" | head -n 1 | cut -d= -f2- | tr -d '"')
				_maintainer=$(grep '^maintainer=' "$_tpl" | head -n 1 | cut -d= -f2- | sed 's/ <.*//' | tr -d '"')
				_short_desc=$(grep '^short_desc=' "$_tpl" | head -n 1 | cut -d= -f2- | tr -d '"')

				printf '<tr><td><strong>%s</strong></td><td>%s</td><td><a href="%s">%s</a></td><td>%s</td><td>%s</td></tr>\n' \
					"$_pkg" "$_version" "$_homepage" "$_homepage" "$_maintainer" "$_short_desc"
				_pkg_count=$((_pkg_count + 1))
			done

			printf '</tbody>\n</table>\n'
		} > "$_pkg_tmp"

		cp "${SCRIPT_DIR}/src/svg-color.html" "$_svg_tmp" 2>/dev/null || touch "$_svg_tmp"

		sed \
			-e "s|__ARCH__|${_arch}|g" \
			-e 's|__CSS_URL__|../style.css|g' \
			-e 's|__HOME_URL__|../index.html|g' \
			-e "s|__REPO_URL__|${_repo_url}|g" \
			-e "s|__GIT_CI_URL__|${REPO_URL:-${SURFER_URL}}|g" \
			-e 's|__FAVICON__|<link rel="icon" href="../favicon.ico" />|g' \
			"$_template" \
		| awk \
			-v nav="$_nav_tmp" \
			-v tbl="$_pkg_tmp" \
			-v svg="$_svg_tmp" \
			'/__NAV_ARCH_LINKS__/ { while ((getline ln < nav) > 0) print ln; close(nav); next }
			 /__PACKAGE_TABLE__/  { while ((getline ln < tbl) > 0) print ln; close(tbl); next }
			 /__SVGCOLOR__/       { while ((getline ln < svg) > 0) print ln; close(svg); next }
			 { print }' \
		> "$_out"

		rm -f "$_nav_tmp" "$_pkg_tmp" "$_svg_tmp"
		echo "  Generated ($_pkg_count packages): docs/${_arch}/index.html"
	done
}

# --- Named targets ---

target_serve() {
	if [ ! -f docs/index.html ]; then
		_r "Site not built!"
		ask 'Build first?' && build_site "$@" || _re "Exiting"
	fi

	_g 'Press Ctrl+C to stop'
	python3 -m http.server -d docs 8000
}

# --- Upload ---

do_upload() {
	[ -n "$ARCH" ]         || fatal 'ARCH is required'
	[ -n "$SURFER_TOKEN" ] || fatal 'SURFER_TOKEN is required'
	[ -n "$PRIV_KEY" ]     || fatal 'PRIV_KEY is required'

	_builddir="${BUILDDIR:-$(pwd)}"
	_webdav="${SURFER_URL}/_webdav/${ARCH}"

	if ! ls "${_builddir}"/*.xbps 1>/dev/null 2>&1; then
		echo 'No packages to upload'
		return 0
	fi

	_work_dir=$(mktemp -d)

	curl -s -X MKCOL "${_webdav}/" -u ":${SURFER_TOKEN}" || true

	echo '==> Fetching remote package list'
	_remote_list=$(fetch_remote_list "$_webdav")

	cd "$_work_dir" || fatal "Cannot cd to $_work_dir"

	echo '==> Downloading repodata'
	curl -sf -o "${ARCH}-repodata" "${SURFER_URL}/${ARCH}/${ARCH}-repodata" \
		-u ":${SURFER_TOKEN}" 2>/dev/null || true

	cp "${_builddir}"/*.xbps . 2>/dev/null || true
	cp "${_builddir}"/*.xbps.sig2 . 2>/dev/null || true

	echo '==> Cleaning old package versions from remote'
	for _new_pkg in "${_builddir}"/*.xbps; do
		[ -f "$_new_pkg" ] || continue
		_new_basename=$(basename "$_new_pkg")
		_name=$(pkg_name "${_new_basename%.xbps}")

		_fmt_list=$(printf '%s\n' $_remote_list)
		echo "$_fmt_list" | grep "^${_name}-[0-9]" | while IFS= read -r _old_pkg; do
			[ "$_old_pkg" = "$_new_basename" ] && continue
			echo "  Deleting old: $_old_pkg"
			delete_remote "${_webdav}/${_old_pkg}"
			delete_remote "${_webdav}/${_old_pkg}.sig2"
		done
	done

	prune_orphans

	echo '==> Updating repository index'
	xbps-rindex -a ./*.xbps 2>/dev/null || true

	echo '==> Signing repository'
	printf '%s\n' "$PRIV_KEY" > private.pem
	chmod 600 private.pem
	xbps-rindex -s --signedby "$SIGNED_BY" --privkey private.pem "$PWD"
	rm -f private.pem

	echo '==> Uploading'
	for _file in ./*.xbps ./*.xbps.sig2 ./*-repodata; do
		[ -f "$_file" ] || continue
		_fname=$(basename "$_file")
		upload_file "$_file" "${_webdav}/${_fname}"
	done

	rm -rf "$_work_dir"
	echo "==> Done: ${SURFER_URL}/${ARCH}/"
}

# --- Main ---

main() {
	# Map named targets to getopts-style args
	case "${1:-}" in
		help|--help)     set -- -h ;;
		update)          set -- -u ;;
		build|web)       set -- -w ;;
		upload|publish)  set -- -p ;;
		serve)           set -- -s ;;
		archs)           set -- -a ;;
	esac

	_opt='' OPTIND=1 OPTARG=''
	_do_update='' _do_packages='' _do_web='' _do_archs=''
	while getopts 'huwpsa' _opt; do
		case "$_opt" in
			h) usage; return 0 ;;
			u) _do_update=1 ;;
			w) _do_web=1 ;;
			p) _do_packages=1 ;;
			s) target_serve; return 0 ;;
			a) _do_archs=1 ;;
			*) usage >&2; return 1 ;;
		esac
	done

	[ "$_do_update$_do_packages$_do_web$_do_archs" = 1 ] ||
		{ usage >&2; return 1; }

	if [ "$_do_update" = 1 ] || [ "$_do_web" = 1 ]; then
		[ -d "$SRCPKGS" ] || fatal "srcpkgs directory not found: ${SRCPKGS}"
	fi

	if [ "$_do_update" = 1 ]; then
		[ -f "$README" ] || fatal "README not found: ${README}"
		generate_list
		generate_readme
		generate_build_yml
		detect_changes
	fi
	if [ "$_do_web" = 1 ]; then
		build_site
	fi
	if [ "$_do_archs" = 1 ] && [ "$_do_web" != 1 ]; then
		generate_arch_pages
	fi
	if [ "$_do_packages" = 1 ]; then
		do_upload
	fi
}

main "$@"
