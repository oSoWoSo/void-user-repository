# License: GPL-3.0-only

[ -f .env ] && . .env

SRCPKGS='srcpkgs'
TEMPLATES_LIST='.github/templatesList'
README='README.md'
WORKFLOW='.github/workflows/build.yml'
BUILD_TEMPLATE='.github/build.yml.in'

SURFER_URL="https://repo.osowoso.org"
CI_URL="${CI_URL:-https://github.com/oSoWoSo/Void_Community_Repository}"
SIGNED_BY="zenobit <zenobit@disroot.org>"
SCRIPT_DIR=$(cd -- "$(dirname -- "$0")" && pwd)
ARCHES='x86_64 x86_64-musl aarch64 aarch64-musl'

. "${SCRIPT_DIR}/.github/pkg-helpers.sh"

# --- UI helpers (ANSI) ---

if [ -z "$NO_COLOR" ]; then
	RED=$(printf '\033[0;31m')
	GREEN=$(printf '\033[0;32m')
	YELLOW=$(printf '\033[1;33m')
	BLUE=$(printf '\033[0;34m')
	NC=$(printf '\033[0m')
fi
_r()  { echo "${RED}${1}${NC}"; }
_re() { echo "${RED}${1}${NC}" >&2; exit 1; }
_g()  { echo "${GREEN}${1}${NC}"; }
_b()  { echo "${BLUE}${1}${NC}"; }
_y()  { echo "${YELLOW}${1}${NC}"; }
ask() {
	printf '%s%s [Y/n] %s' "$YELLOW" "$1" "$NC"
	read -r _ans || _ans=y
	case "$_ans" in [Nn]*) return 1 ;; *) return 0 ;; esac
}

# --- Core helpers ---

fatal() {
	echo '[FATAL]' "$@" >&2
	exit 1
}

usage() {
	prog=${0##*/}
	cat <<-EOF
	Usage: $prog -h | -u | -w | -p | -s | -a
	       $prog {update|build|upload|serve|archs|help}

	Manage repository: templates, README, build.yml, website, and packages.

	Options
	  -u, --update     update list, README, and build.yml
	  -w, --build      regenerate website (requires pandoc)
	  -p, --upload     upload built packages to WebDAV repository
	  -s, --serve      serve website locally on port 8000
	  -a, --archs      regenerate architecture pages only
	  -h, --help       print this message

	Compound: $prog -uw   (update + build)
	EOF
}

# --- Template field extraction ---

# Single-pass extraction of common template fields.
# Usage: read_template_fields <template_path>
# Sets _tpl_version _tpl_homepage _tpl_maintainer _tpl_short_desc _tpl_archs
read_template_fields() {
	_tpl_version='' _tpl_homepage='' _tpl_maintainer=''
	_tpl_short_desc='' _tpl_archs=''
	while IFS= read -r _ln; do
		case "$_ln" in
			version=*)    [ -z "$_tpl_version" ]    && _tpl_version=${_ln#version=} ;;
			homepage=*)   [ -z "$_tpl_homepage" ]   && _tpl_homepage=${_ln#homepage=} ;;
			maintainer=*) [ -z "$_tpl_maintainer" ] && _tpl_maintainer=${_ln#maintainer=} ;;
			short_desc=*) [ -z "$_tpl_short_desc" ] && _tpl_short_desc=${_ln#short_desc=} ;;
			archs=*)      [ -z "$_tpl_archs" ]      && _tpl_archs=${_ln#archs=} ;;
		esac
	done < "$1"
	_tpl_version=${_tpl_version#\"};   _tpl_version=${_tpl_version%\"}
	_tpl_homepage=${_tpl_homepage#\"}; _tpl_homepage=${_tpl_homepage%\"}
	_tpl_maintainer=${_tpl_maintainer#\"}; _tpl_maintainer=${_tpl_maintainer%\"}
	_tpl_maintainer=${_tpl_maintainer%% <*}
	_tpl_short_desc=${_tpl_short_desc#\"}; _tpl_short_desc=${_tpl_short_desc%\"}
	_tpl_archs=${_tpl_archs#\"}; _tpl_archs=${_tpl_archs%\"}
}

# --- Package helpers ---

pkg_name() {
	# Accept either `name-version_revision` or `name-version_revision.arch`
	# (callers may or may not have stripped the .xbps suffix already).
	_pn_in="${1%.xbps}"
	case "$_pn_in" in *.*) _pn_in="${_pn_in%.*}" ;; esac
	if command -v xbps-uhelper >/dev/null 2>&1; then
		_pn_out=$(xbps-uhelper getpkgname "$_pn_in" 2>/dev/null) \
			&& [ -n "$_pn_out" ] && { printf '%s' "$_pn_out"; return; }
	fi
	# Fallback parser: name-version_revision -> drop last `-segment`
	_pn_ver="${_pn_in##*-}"
	printf '%s' "${_pn_in%-"${_pn_ver}"}"
}

# List packages PUBLISHED at the public URL for <arch>, one name per line.
# Prefers `xbps-query` (canonical, validates signature); falls back to
# fetching the repodata and parsing with python so the website can be
# regenerated in environments without xbps (e.g. ubuntu-latest in CI).
# Returns 0 on success (output may be empty -- that means the repo is
# really empty for this arch), nonzero on failure.
list_published_pkgs() {
	_lpp_arch="$1"
	_lpp_url="${SURFER_URL}/${_lpp_arch}"
	_lpp_tmp=$(mktemp)
	_lpp_rc=1

	if command -v xbps-query >/dev/null 2>&1 \
			&& command -v xbps-uhelper >/dev/null 2>&1; then
		_lpp_root=$(mktemp -d)
		# --rootdir on a fresh tempdir + -i + -M ensures we only see
		# packages from the specified --repository (no xbps.d, no cache,
		# no installed-pkg state interfering). XBPS_TARGET_ARCH handles
		# cross-arch listing (aarch64-musl, etc.).
		XBPS_TARGET_ARCH="$_lpp_arch" \
			xbps-query --rootdir="$_lpp_root" --repository="$_lpp_url" \
				-R -M -i -s '' > "$_lpp_tmp" 2>/dev/null
		_lpp_rc=$?
		rm -rf "$_lpp_root"
		if [ "$_lpp_rc" -eq 0 ]; then
			# Output: "[STATUS] pkgname-version_revision  short_desc"
			awk '{print $2}' "$_lpp_tmp" | while IFS= read -r _pv; do
				[ -n "$_pv" ] || continue
				xbps-uhelper getpkgname "$_pv" 2>/dev/null
			done
			rm -f "$_lpp_tmp"
			return 0
		fi
	fi

	# Fallback: fetch the signed repodata and read index.plist with python.
	if command -v python3 >/dev/null 2>&1; then
		if curl -fsS -o "$_lpp_tmp" \
				"${_lpp_url}/${_lpp_arch}-repodata" 2>/dev/null; then
			python3 "${SCRIPT_DIR}/.github/repodata-list.py" "$_lpp_tmp"
			_lpp_rc=$?
		else
			_lpp_rc=1
		fi
	fi

	rm -f "$_lpp_tmp"
	return "$_lpp_rc"
}

# Returns 0 on success (printing the file list, possibly empty),
# nonzero on transport failure (network/auth) so callers can react.
fetch_remote_list() {
	_frl_body=$(curl -fsS -X PROPFIND "${1}/" \
		-H 'Depth: 1' \
		-u ":${SURFER_TOKEN}" 2>&1)
	_frl_rc=$?
	if [ "$_frl_rc" -ne 0 ]; then
		echo "Error: PROPFIND ${1} failed (rc=${_frl_rc}): ${_frl_body}" >&2
		return "$_frl_rc"
	fi
	printf '%s' "$_frl_body" \
		| grep -o '<D:href>[^<]*\.xbps</D:href>' \
		| sed 's|<D:href>||;s|</D:href>||;s|.*/||'
}

delete_remote() {
	curl -s -X DELETE "${1}" -u ":${SURFER_TOKEN}" || true
}

upload_file() {
	_file="$1" _dest="$2"
	echo "  Uploading: $(basename "$_file")"
	curl -s -T "$_file" "$_dest" -u ":${SURFER_TOKEN}" \
		|| { echo "  Warning: failed to upload $(basename "$_file")"; return 1; }
}

prune_orphans() {
	# Args:
	#   $1: remote pkg list (one filename per line)
	#   $2: optional path to write orphan PACKAGE NAMES (dedup, one per line)
	_remote_list="$1"
	_orphans_out="${2:-}"
	[ -n "$_orphans_out" ] && : > "$_orphans_out"
	echo '==> Pruning orphan packages (no template in srcpkgs)'
	_srcpkgs="${SCRIPT_DIR}/${SRCPKGS}"
	printf '%s\n' "$_remote_list" | while IFS= read -r _remote_pkg; do
		[ -n "$_remote_pkg" ] || continue
		_pkg=$(pkg_name "${_remote_pkg%.xbps}")
		[ -d "${_srcpkgs}/${_pkg}" ] && continue
		echo "  Removing orphan: $_remote_pkg ($_pkg)"
		delete_remote "${_webdav}/${_remote_pkg}"
		delete_remote "${_webdav}/${_remote_pkg}.sig2"
		[ -n "$_orphans_out" ] && printf '%s\n' "$_pkg" >> "$_orphans_out"
	done
	if [ -n "$_orphans_out" ] && [ -s "$_orphans_out" ]; then
		# Dedup in place (multiple .xbps per name from subpackages etc.)
		sort -u -o "$_orphans_out" "$_orphans_out"
	fi
}

# --- Website helpers (from create-web) ---

_build_main_index() {
	_title="${1:-Void Community Repository}"

	_nav_arch_tmp=$(mktemp)
	_readme_tmp=$(mktemp)
	_svg_tmp=$(mktemp)

	for _arch in $ARCHES; do
		printf '  <li><a href="%s/">%s</a></li>\n' "$_arch" "$_arch" >> "$_nav_arch_tmp"
	done
	printf '  <li><a href="https://codeberg.org/osowoso/oco">&#x2934; source</a></li>\n' >> "$_nav_arch_tmp"
	if [ -n "${CI_URL:-}" ]; then
		printf '  <li><a href="%s">CI</a></li>\n' "$CI_URL" >> "$_nav_arch_tmp"
	fi

	pandoc README.md -f gfm > "$_readme_tmp"
	cp src/svg-color.html "$_svg_tmp"

	sed \
		-e "s|__CSS_URL__|style.css|g" \
		-e 's|__FAVICON__|<link rel="icon" href="favicon.ico" />|g' \
		.github/main-index-template.html \
	| awk \
		-v nav_arch="$_nav_arch_tmp" \
		-v readme="$_readme_tmp" \
		-v svg="$_svg_tmp" \
		'/__NAV_ARCH_LINKS__/ { while ((getline ln < nav_arch) > 0) print ln; close(nav_arch); next }
		 /__README_CONTENT__/  { while ((getline ln < readme)   > 0) print ln; close(readme);   next }
		 /__SVGCOLOR__/        { while ((getline ln < svg)      > 0) print ln; close(svg);       next }
		 { print }' \
	> "docs/index.html"

	rm -f "$_nav_arch_tmp" "$_readme_tmp" "$_svg_tmp"
	_g "Generated: docs/index.html"
}

# --- Update ---

generate_list() {
	new_list=$(for _entry in "$SRCPKGS"/*/; do
		[ -d "$_entry" ] || [ -L "$_entry" ] || continue
		_pkg=${_entry%/}
		_pkg=${_pkg##*/}
		echo "$_pkg"
	done | sort -f)

	mkdir -p "$(dirname "$TEMPLATES_LIST")"
	if [ -f "$TEMPLATES_LIST" ] && [ "$new_list" = "$(cat "$TEMPLATES_LIST")" ]; then
		echo 'templatesList: no changes'
	else
		echo "$new_list" > "$TEMPLATES_LIST"
		echo 'templatesList: updated'
	fi
}

generate_readme() {
	_tmp=$(mktemp)

	awk '/^## Available/{exit} {print}' "$README" > "$_tmp"

	{
		echo '## Available templates (packages when built successfully)'
		echo '| package | version | homepage | maintainer | notes |'
		echo '|:--------|:--------|:---------|:-----------|:------|'
		while IFS= read -r _pkg; do
			_tpl="$SRCPKGS/$_pkg/template"
			[ -f "$_tpl" ] || continue
			read_template_fields "$_tpl"
			echo "| $_pkg | $_tpl_version | $_tpl_homepage | $_tpl_maintainer | $_tpl_archs |"
		done < "$TEMPLATES_LIST"
	} >> "$_tmp"

	mv "$_tmp" "$README"
	echo "README: updated"
}

generate_build_yml() {
	[ -f "$BUILD_TEMPLATE" ] || fatal "not found: ${BUILD_TEMPLATE}"
	[ -f "$TEMPLATES_LIST" ] || fatal "not found: ${TEMPLATES_LIST}"

	mkdir -p "$(dirname "$WORKFLOW")"

	_opts=$(mktemp)
	while IFS= read -r _pkg; do
		[ -z "$_pkg" ] && continue
		printf '        - %s\n' "$_pkg"
	done < "$TEMPLATES_LIST" > "$_opts"

	awk -v opts="$_opts" '
		/^[[:space:]]*__TEMPLATE_OPTIONS__[[:space:]]*$/ {
			while ((getline ln < opts) > 0) print ln
			close(opts)
			next
		}
		{ print }
	' "$BUILD_TEMPLATE" > "$WORKFLOW"

	rm -f "$_opts"
	echo "build.yml: updated"
}

detect_changes() {
	if ! git rev-parse HEAD~1 >/dev/null 2>&1; then
		echo '==> First commit'
		_added=$(cat "$TEMPLATES_LIST")
		_modified=''
		_removed=''
	else
		_diff=$(git diff --name-status HEAD~1 HEAD -- "$SRCPKGS")
		_added=$(   echo "$_diff" | awk '$1=="A"{print $2}' | cut -d/ -f2 | sort -u)
		_modified=$(echo "$_diff" | awk '$1=="M"{print $2}' | cut -d/ -f2 | sort -u)
		_removed=$( echo "$_diff" | awk '$1=="D"{print $2}' | cut -d/ -f2 | sort -u)
	fi

	_added=$(echo "$_added"     | sed '/^$/d')
	_modified=$(echo "$_modified" | sed '/^$/d')
	_removed=$(echo "$_removed"   | sed '/^$/d')

	echo "==> Added:   $(echo "$_added" | tr '\n' ' ')"
	echo "==> Modified: $(echo "$_modified" | tr '\n' ' ')"
	echo "==> Removed: $(echo "$_removed" | tr '\n' ' ')"
}

# --- Web ---

build_site() {
	_title="${1:-Void Community Repository}"

	if ! command -v pandoc >/dev/null 2>&1; then
		echo "pandoc: not installed, skipping website"
		return
	fi

	if [ -f docs/CNAME ]; then
		cp docs/CNAME src/
	fi
	rm -rf docs && mkdir -p docs
	cp -r src/* docs/
	rm -f docs/toggle.html docs/toc.html docs/svg-color.html docs/footer.html

	_build_main_index "$_title"
	generate_arch_pages
	_g "Finished"

	if [ -n "${SURFER_TOKEN:-}" ]; then
		_webdav="${SURFER_URL}/_webdav"
		echo '==> Uploading website assets'
		_ws_failed=0
		for _file in "${SCRIPT_DIR}/docs"/*; do
			[ -f "$_file" ] || continue
			upload_file "$_file" "${_webdav}/$(basename "$_file")" || _ws_failed=1
		done
		[ "$_ws_failed" -eq 0 ] || echo '==> Warning: some website asset uploads failed'
	fi
}

generate_arch_pages() {
	_template="${SCRIPT_DIR}/.github/arch-index-template.html"
	[ -f "$_template" ] || { echo "arch-index-template.html not found, skipping arch pages"; return 1; }

	_pkg_list=$(for _entry in "$SRCPKGS"/*/; do
		[ -d "$_entry" ] || [ -L "$_entry" ] || continue
		_p=${_entry%/}; _p=${_p##*/}; echo "$_p"
	done | sort -f)

	for _arch in $ARCHES; do
		_out_dir="${SCRIPT_DIR}/docs/${_arch}"
		_out="${_out_dir}/index.html"
		_repo_url="${SURFER_URL}/${_arch}"

		mkdir -p "$_out_dir"

		_nav_tmp=$(mktemp)
		_pkg_tmp=$(mktemp)
		_svg_tmp=$(mktemp)

		for _a in $ARCHES; do
			if [ "$_a" = "$_arch" ]; then
				printf '  <li><a href="." class="active">%s</a></li>\n' "$_arch" >> "$_nav_tmp"
			else
				printf '  <li><a href="../%s/">%s</a></li>\n' "$_a" "$_a" >> "$_nav_tmp"
			fi
		done

		# Determine which packages are actually PUBLISHED for this arch.
		# Source of truth: the public URL (repo.osowoso.org/${arch}/),
		# read via `list_published_pkgs` which prefers xbps-query and
		# falls back to fetching+parsing the repodata.
		#
		# _have_remote=1: authoritative listing (even if empty) -- pages
		# show only the intersection of srcpkgs and what's published.
		# _have_remote='':  listing unavailable -- fall back to showing
		# every compatible template, with a warning.
		_have_remote=''
		_remote_names=''
		_lpf=$(mktemp)
		# Capture list_published_pkgs's exit BEFORE the pipe to sort,
		# otherwise sort's success would mask a transport/parse failure.
		if list_published_pkgs "$_arch" > "$_lpf"; then
			_have_remote=1
			_remote_names=$(sort -u "$_lpf")
		else
			_y "Warning: could not list published packages for ${_arch}; rendering full template list"
		fi
		rm -f "$_lpf"

		{
			printf '<table>\n<thead><tr>\n'
			printf '  <th>package</th><th>version</th><th>homepage</th><th>maintainer</th><th>description</th>\n'
			printf '</tr></thead>\n<tbody>\n'

			_pkg_count=0
			for _pkg in $_pkg_list; do
				pkg_arch_ok "$_pkg" "$_arch" || continue
				_tpl="${SRCPKGS}/${_pkg}/template"
				[ -f "$_tpl" ] || continue

				if [ "$_have_remote" = 1 ]; then
					printf '%s\n' "$_remote_names" | grep -qx "$_pkg" || continue
				fi

				read_template_fields "$_tpl"

				printf '<tr><td><strong>%s</strong></td><td>%s</td><td><a href="%s">%s</a></td><td>%s</td><td>%s</td></tr>\n' \
					"$_pkg" "$_tpl_version" "$_tpl_homepage" "$_tpl_homepage" "$_tpl_maintainer" "$_tpl_short_desc"
				_pkg_count=$((_pkg_count + 1))
			done

			printf '</tbody>\n</table>\n'
		} > "$_pkg_tmp"

		cp "${SCRIPT_DIR}/src/svg-color.html" "$_svg_tmp" 2>/dev/null || touch "$_svg_tmp"

		sed \
			-e "s|__ARCH__|${_arch}|g" \
			-e 's|__CSS_URL__|../style.css|g' \
			-e 's|__HOME_URL__|../index.html|g' \
			-e "s|__REPO_URL__|${_repo_url}|g" \
			-e "s|__GIT_CI_URL__|${CI_URL}|g" \
			-e 's|__FAVICON__|<link rel="icon" href="../favicon.ico" />|g' \
			"$_template" \
		| awk \
			-v nav="$_nav_tmp" \
			-v tbl="$_pkg_tmp" \
			-v svg="$_svg_tmp" \
			'/__NAV_ARCH_LINKS__/ { while ((getline ln < nav) > 0) print ln; close(nav); next }
			 /__PACKAGE_TABLE__/  { while ((getline ln < tbl) > 0) print ln; close(tbl); next }
			 /__SVGCOLOR__/       { while ((getline ln < svg) > 0) print ln; close(svg); next }
			 { print }' \
		> "$_out"

		rm -f "$_nav_tmp" "$_pkg_tmp" "$_svg_tmp"
		echo "  Generated ($_pkg_count packages): docs/${_arch}/index.html"

		if [ -n "${SURFER_TOKEN:-}" ]; then
			_webdav_arch="${SURFER_URL}/_webdav/${_arch}"
			curl -s -X MKCOL "${_webdav_arch}/" -u ":${SURFER_TOKEN}" || true
			upload_file "$_out" "${_webdav_arch}/index.html" \
				|| echo "  Warning: failed to upload ${_arch}/index.html"
		fi
	done
}

# --- Named targets ---

target_serve() {
	if [ ! -f docs/index.html ]; then
		_r "Site not built!"
		ask 'Build first?' && build_site "$@" || _re "Exiting"
	fi

	_g 'Press Ctrl+C to stop'
	python3 -m http.server -d docs 8000
}

# --- Upload ---

do_upload() {
	[ -n "$ARCH" ]         || fatal 'ARCH is required'
	[ -n "$SURFER_TOKEN" ] || fatal 'SURFER_TOKEN is required'
	[ -n "$PRIV_KEY" ]     || fatal 'PRIV_KEY is required'

	_builddir="${BUILDDIR:-$(pwd)}"
	_webdav="${SURFER_URL}/_webdav/${ARCH}"

	_work_dir=$(mktemp -d)

	curl -s -X MKCOL "${_webdav}/" -u ":${SURFER_TOKEN}" || true

	echo '==> Fetching remote package list'
	if ! _remote_list=$(fetch_remote_list "$_webdav"); then
		fatal 'PROPFIND failed; refusing to upload with unknown remote state'
	fi
	[ -z "$_remote_list" ] && echo '  Note: remote package list is empty (repo empty or first run)'

	# Run all temp-dir work in a subshell so cleanup is guaranteed on any exit.
	(
		cd "$_work_dir" || exit 1

		echo '==> Downloading repodata'
		_repodata_http=$(curl -sS -o "${ARCH}-repodata" \
			-w '%{http_code}' \
			"${SURFER_URL}/${ARCH}/${ARCH}-repodata" \
			-u ":${SURFER_TOKEN}" 2>/dev/null) || _repodata_http=0
		case "$_repodata_http" in
			200) ;;
			404)
				echo '==> No repodata yet (first run); starting fresh'
				rm -f "${ARCH}-repodata"
				;;
			*)
				rm -f "${ARCH}-repodata"
				echo "==> Error: repodata fetch returned HTTP ${_repodata_http}" >&2
				exit 1
				;;
		esac

		if ls "${_builddir}"/*.xbps 1>/dev/null 2>&1; then
			cp "${_builddir}"/*.xbps . 2>/dev/null || true
			cp "${_builddir}"/*.xbps.sig2 . 2>/dev/null || true

			echo '==> Cleaning old package versions from remote'
			for _new_pkg in "${_builddir}"/*.xbps; do
				[ -f "$_new_pkg" ] || continue
				_new_basename=$(basename "$_new_pkg")
				_name=$(pkg_name "${_new_basename%.xbps}")

				# Shell glob match treats '+', '.', etc. literally -- unlike grep.
				printf '%s\n' "$_remote_list" | while IFS= read -r _old_pkg; do
					case "$_old_pkg" in
						"${_name}-"[0-9]*) ;;
						*) continue ;;
					esac
					# Also reject names that share a common prefix
					# (e.g. "foo-3.0" must not match for _name="fo").
					_old_pkg_name=$(pkg_name "${_old_pkg%.xbps}")
					[ "$_old_pkg_name" = "$_name" ] || continue
					[ "$_old_pkg" = "$_new_basename" ] && continue
					echo "  Deleting old: $_old_pkg"
					delete_remote "${_webdav}/${_old_pkg}"
					delete_remote "${_webdav}/${_old_pkg}.sig2"
				done
			done
		else
			echo '==> No new packages to upload'
		fi

		prune_orphans "$_remote_list" "${PWD}/orphans.txt"

		if [ -s "${PWD}/orphans.txt" ] && [ -f "${ARCH}-repodata" ]; then
			echo '==> Stripping orphan entries from local repodata'
			if command -v python3 >/dev/null 2>&1; then
				# xargs avoids unquoted-expansion globbing on orphan names
				xargs python3 "${SCRIPT_DIR}/.github/repodata-strip.py" \
					"${ARCH}-repodata" < "${PWD}/orphans.txt" \
					|| echo '  Warning: repodata-strip failed; index may reference deleted packages' >&2
			else
				echo '  Warning: python3 not found; index will keep references to deleted packages' >&2
			fi
		fi

		if ls ./*.xbps 1>/dev/null 2>&1; then
			echo '==> Updating repository index'
			xbps-rindex -a ./*.xbps 2>/dev/null || true
		fi

		echo '==> Signing repository'
		# Restrictive umask before write avoids a world-readable window
		# between create-with-default-umask and chmod 600.
		trap 'rm -f private.pem' EXIT INT TERM
		( umask 077 && printf '%s\n' "$PRIV_KEY" > private.pem )
		xbps-rindex -s --signedby "$SIGNED_BY" --privkey private.pem "$PWD"
		rm -f private.pem

		echo '==> Uploading'
		_upload_failed=0
		for _file in ./*.xbps ./*.xbps.sig2 ./*-repodata; do
			[ -f "$_file" ] || continue
			_fname=$(basename "$_file")
			upload_file "$_file" "${_webdav}/${_fname}" || _upload_failed=1
		done
		[ "$_upload_failed" -eq 0 ] || { echo '==> Error: one or more uploads failed'; exit 1; }
	)
	_upload_status=$?
	rm -rf "$_work_dir"
	[ "$_upload_status" -eq 0 ] || return "$_upload_status"
	echo "==> Done: ${SURFER_URL}/${ARCH}/"
}

# --- Main ---

main() {
	# Map named targets to getopts-style args
	case "${1:-}" in
		help|--help)     set -- -h ;;
		update)          set -- -u ;;
		build|web)       set -- -w ;;
		upload|publish)  set -- -p ;;
		serve)           set -- -s ;;
		archs)           set -- -a ;;
	esac

	_opt='' OPTIND=1 OPTARG=''
	_do_update='' _do_packages='' _do_web='' _do_archs=''
	while getopts 'huwpsa' _opt; do
		case "$_opt" in
			h) usage; return 0 ;;
			u) _do_update=1 ;;
			w) _do_web=1 ;;
			p) _do_packages=1 ;;
			s) target_serve; return 0 ;;
			a) _do_archs=1 ;;
			*) usage >&2; return 1 ;;
		esac
	done

	[ -n "$_do_update$_do_packages$_do_web$_do_archs" ] ||
		{ usage >&2; return 1; }

	if [ "$_do_update" = 1 ] || [ "$_do_web" = 1 ]; then
		[ -d "$SRCPKGS" ] || fatal "srcpkgs directory not found: ${SRCPKGS}"
	fi

	if [ "$_do_update" = 1 ]; then
		[ -f "$README" ] || fatal "README not found: ${README}"
		generate_list
		generate_readme
		generate_build_yml
		detect_changes
	fi
	if [ "$_do_web" = 1 ]; then
		build_site
	fi
	if [ "$_do_archs" = 1 ] && [ "$_do_web" != 1 ]; then
		generate_arch_pages
	fi
	if [ "$_do_packages" = 1 ]; then
		do_upload
	fi
}

main "$@"
