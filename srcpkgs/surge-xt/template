post_extract() {
	vsrcextract -C libs/JUCE "${_JUCE}.tar.gz"
	vsrcextract -C libs/LuaJitLib/LuaJIT "${_LuaJIT}.tar.gz"
	vsrcextract -C libs/PEGTL "${_PEGTL}.tar.gz"
	vsrcextract -C libs/clap-juce-extensions "${_extensions}.tar.gz"
	vsrcextract -C libs/eurorack/eurorack "${_eurorack}.tar.gz"
	vsrcextract -C libs/fmt "${_fmt}.tar.gz"
	vsrcextract -C libs/libsamplerate "${_libsamplerate}.tar.gz"
	vsrcextract -C libs/melatonin_inspector "${_melatonin}.tar.gz"
	vsrcextract -C libs/oddsound-mts/MTS-ESP "${_ESP}.tar.gz"
	vsrcextract -C libs/pffft "${_pffft}.tar.gz"
	vsrcextract -C libs/pybind11 "${_pybind11}.tar.gz"
	vsrcextract -C libs/simde "${_simde}.tar.gz"
	vsrcextract -C libs/sst/sst-basic-blocks "${_blocks}.tar.gz"
	vsrcextract -C libs/sst/sst-cpputils "${_cpputils}.tar.gz"
	vsrcextract -C libs/sst/sst-effects "${_effects}.tar.gz"
	vsrcextract -C libs/sst/sst-filters "${_filters}.tar.gz"
	vsrcextract -C libs/sst/sst-plugininfra "${_plugininfra}.tar.gz"
	vsrcextract -C libs/sst/sst-waveshapers "${_waveshapers}.tar.gz"
	vsrcextract -C libs/tuning-library "${_tuning}.tar.gz"
	vsrcextract -C libs/clap-juce-extensions/clap-libs/clap "${_clap}.tar.gz"
	vsrcextract -C libs/clap-juce-extensions/clap-libs/clap-helpers "${_helpers}.tar.gz"
	vsrcextract -C libs/simde/test/munit "${_munit}.tar.gz"
	vsrcextract -C libs/sst/sst-plugininfra/libs/filesystem/ghc-filesystem "${_filesystem}.tar.gz"
	vsrcextract -C libs/sst/sst-plugininfra/libs/miniz "${_miniz}.tar.gz"

	# some extra skins
	mkdir skins
	vsrcextract -C skins "${_skins}.tar.gz"
	mv skins/Skins/* resources/data/skins
	rm -r resources/data/skins/_previews
}

pre_build() {
	# Get rid of those spaces and capital letters
	sed -i 's/Surge XT/surge-xt/g' src/surge-xt/CMakeLists.txt
	sed -i 's/Surge XT Effects/surge-xt-effects/g' src/surge-fx/CMakeLists.txt
}

surge-xt-common_package() {
	short_desc+=" - documentation, extra patches and skins"
	pkg_install() {
		vmove usr/share/surge-xt
		vmkdir usr/share/doc/surge-xt
		vcopy ${XBPS_BUILDDIR}/${sourcepkg}-${version}/doc/* usr/share/doc/surge-xt
	}
}

surge-xt-lv2_package() {
	short_desc+=" - lv2 only"
	depends+=" lv2"
	pkg_install() {
		vmove usr/lib/lv2
	}
}

surge-xt-vst3_package() {
	short_desc+=" - vst3 only"
	pkg_install() {
		vmove usr/lib/vst3
	}
}

surge-xt-clap_package() {
	short_desc+=" - clap only"
	pkg_install() {
		vmove usr/lib/clap
	}
}

surge-xt-standalone_package() {
	short_desc+=" - standalone only"
	pkg_install() {
		vmove usr/bin
		vmkdir usr/share/applications
		vmkdir usr/share/icons/hicolor/512x512/apps
		vcopy ${XBPS_BUILDDIR}/${sourcepkg}-${version}/resources/assets/Logo/PNG/surge_icon_512.png usr/share/icons/hicolor/512x512/apps/surge-xt.png
		vcopy ${XBPS_BUILDDIR}/${sourcepkg}-${version}/resources/assets/Logo/PNG/surge_fx_icon_512.png usr/share/icons/hicolor/512x512/apps/surge-fx.png
		cd ${PKGDESTDIR}/usr/share/applications
		# generate desktop file
		gendesk -n \
		  --exec surge-xt \
		  --name surge-xt \
		  --pkgname surge-xt \
		  --pkgdesc "${short_desc}" \
		  --icon surge-xt \
		  --genericname "${short_desc}"
		gendesk -n \
		  --exec surge-xt-effects \
		  --name surge-fx \
		  --pkgname surge-fx \
		  --pkgdesc "${short_desc}" \
		  --icon surge-fx \
		  --genericname "surge-xt effects"
	}
}
