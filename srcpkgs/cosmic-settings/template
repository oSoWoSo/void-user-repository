hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel eudev-libudev-devel libinput-devel mold
 pipewire-devel clang17-devel"
depends="accountsservice cosmic-settings-daemon dbus-libs eudev-libudev
 gettext xkeyboard-config lame libpulseaudio libxkbcommon libpipewire libsndfile
 libxcb libasyncns libflac libvorbis libogg libmpg123 libXau libXdmcp opus
