depends="accountsservice cosmic-settings-daemon dbus-libs eudev-libudev gettext xkeyboard-config lame libpulseaudio libxkbcommon libpipewire libsndfile libxcb libasyncns libflac libvorbis libogg libmpg123 libXau libXdmcp opus iso-codes power-profiles-daemon"
