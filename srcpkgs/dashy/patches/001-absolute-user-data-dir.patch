Support absolute paths in USER_DATA_DIR environment variable.
Upstream uses path.join(rootDir, USER_DATA_DIR) in app.js which does not
handle absolute paths. config-validator.js uses a literal "./" prefix making
it cwd-relative. Fix both to use path.resolve so USER_DATA_DIR=/var/lib/dashy works.

--- a/services/config-validator.js
+++ b/services/config-validator.js
@@ -4,6 +4,7 @@
  */
 
 const fs = require('fs'); // For opening + reading files
+const path = require('path'); // For resolving user data directory
 const yaml = require('js-yaml'); // For parsing YAML
 const Ajv = require('ajv'); // For validating with schema
 
@@ -101,7 +102,9 @@
 let config = {};
 
 try { // Try to open and parse the YAML file
-  config = yaml.load(fs.readFileSync(`./${process.env.USER_DATA_DIR || 'user-data'}/conf.yml`, 'utf8'));
+  const _udDir = path.resolve(
+    process.env.USER_DATA_DIR || path.join(__dirname, '..', 'user-data'));
+  config = yaml.load(fs.readFileSync(path.join(_udDir, 'conf.yml'), 'utf8'));
   validate(config);
 } catch (e) { // Something went very wrong...
   setIsValidVariable(false);
--- a/services/app.js
+++ b/services/app.js
@@ -11,6 +11,11 @@
 /* Project root — one level up from services/ */
 const rootDir = path.join(__dirname, '..');
 
+/* Resolve user data directory — supports both relative and absolute USER_DATA_DIR */
+const userDataDir = process.env.USER_DATA_DIR
+  ? path.resolve(process.env.USER_DATA_DIR)
+  : path.join(rootDir, 'user-data');
+
 /* Import NPM dependencies */
 const yaml = require('js-yaml');
 
@@ -67,7 +72,7 @@
