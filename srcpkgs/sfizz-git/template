case "$XBPS_TARGET_MACHINE" in
	x86_64*|i686*)
		;;
	*)
		configure_args+=" -DSFIZZ_USE_SSE=OFF"
		;;
esac

if [ "$XBPS_TARGET_LIBC" = musl ]; then
	CXXFLAGS+=" -D_LARGEFILE64_SOURCE"
fi

post_extract() {
	vsrcextract -C library "${_sfzlib}.tar.gz"
	vsrcextract -C library/external/abseil-cpp "${_abseil}.tar.gz"
	vsrcextract -C library/external/filesystem "${_filesystem}.tar.gz"
	vsrcextract -C library/external/simde "${_simde}.tar.gz"
	vsrcextract -C library/external/simde/test/munit "${_munit}.tar.gz"
	vsrcextract -C library/external/st_audiofile/thirdparty/dr_libs "${_dr_libs}.tar.gz"
	vsrcextract -C library/external/st_audiofile/thirdparty/dr_libs/tests/external/miniaudio "${_miniaudio}.tar.gz"
	vsrcextract -C library/external/st_audiofile/thirdparty/libaiff "${_libaiff}.tar.gz"
	vsrcextract -C library/external/st_audiofile/thirdparty/wavpack "${_wavpack}.tar.gz"
	vsrcextract -C plugins/editor/external/vstgui4 "${_vstgui}.tar.gz"
	vsrcextract -C plugins/vst/external/VST_SDK/VST3_SDK/base "${_base}.tar.gz"
	vsrcextract -C plugins/vst/external/VST_SDK/VST3_SDK/pluginterfaces "${_pluginterfaces}.tar.gz"
	vsrcextract -C plugins/vst/external/VST_SDK/VST3_SDK/public.sdk "${_sdk}.tar.gz"
	vsrcextract -C plugins/vst/external/sfzt_auwrapper "${_sfzt_auwrapper}.tar.gz"
}

pre_build() {
	sed -i '21s/(/= / ; 21s/)//' plugins/editor/external/vstgui4/vstgui/lib/finally.h
}

sfizz-lv2_package() {
	short_desc+=" - lv2 plugin"
	depends+=" lv2"
	pkg_install() {
		vmove usr/lib/lv2
	}
}

sfizz-vst3_package() {
	short_desc+=" - vst3 plugin"
	pkg_install() {
		vmove usr/lib/vst3
	}
}

sfizz-lib_package() {
	short_desc+=" - c++ library"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/libsfizz.so*
		vmove usr/lib/pkgconfig
		vlicense LICENSE
	}
}

sfizz-cli_package() {
	short_desc+=" - cli jack client"
	pkg_install() {
		vmove usr/bin
		vmove usr/share
	}
}
