# Template file for 'pop-fonts'
pkgname=pop-fonts
version=1
revision=1
hostmakedepends="git"
short_desc="Pop Fonts"
maintainer="Bella Wagner <belladev109@proton.me>"
license="OFL-1.1"
homepage="https://github.com/pop-os/fonts"

do_fetch() {
	git clone $homepage ${pkgname}-${version}
}

do_install() {
	make install DESTDIR=${DESTDIR}
}
