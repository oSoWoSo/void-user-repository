# Template file for 'cosmic-applets'
pkgname=cosmic-applets
version=1.0.12
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel eudev-libudev-devel dbus-devel pulseaudio-devel libinput-devel pipewire-devel clang19-devel"
depends="cosmic-icons dbus-libs eudev-libudev lame libpulseaudio libxkbcommon libpulseaudio libsndfile libxcb libasyncns libflac libvorbis libogg libmpg123 libXau libXdmcp opus"
short_desc="Applets for COSMIC"
maintainer="Bella Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-applets"
distfiles="https://github.com/pop-os/cosmic-applets/archive/refs/tags/epoch-${version}.tar.gz"
checksum=77d1c3a7e6aecec6a54e8490d3350e6a31ecd2b72c2b8b3d2d94aaa348883f76
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir=${DESTDIR} target="${RUST_TARGET}/release" install
}
