post_extract() {
	vsrcextract -C libs/JUCE "${_juce}.tar.gz"
	vsrcextract -C libs/JUCELV2 "${_jucelv2}.tar.gz"
	vsrcextract -C libs/clap-juce-extensions  "${_clapjuce}.tar.gz"
	vsrcextract -C libs/clap-juce-extensions/clap-libs/clap  "${_clap}.tar.gz"
	vsrcextract -C libs/clap-juce-extensions/clap-libs/clap-helpers  "${_claphelp}.tar.gz"
	vsrcextract -C libs/json  "${_json}.tar.gz"
	vsrcextract -C libs/tuning-library  "${_tuning}.tar.gz"
}

odin2-common_package() {
	short_desc+=" - documentation"
	pkg_install() {
		vmkdir usr/share/doc/odin2
		vcopy ${XBPS_BUILDDIR}/${sourcepkg}-${version}/manual/manual.pdf usr/share/doc/odin2
	}
}

odin2-lv2_package() {
	short_desc+=" - lv2 only"
	depends+=" lv2"
	pkg_install() {
		vmove usr/lib/lv2
	}
}

odin2-vst3_package() {
	short_desc+=" - vst3 only"
	pkg_install() {
		vmove usr/lib/vst3
	}
}

odin2-clap_package() {
	short_desc+=" - clap only"
	pkg_install() {
		vmove usr/lib/clap
	}
}

odin2-standalone_package() {
	short_desc+=" - standalone only"
	pkg_install() {
		vmove usr/bin
		vmkdir usr/share/applications
		vmkdir usr/share/icons/hicolor/512x512/apps
		vcopy ${XBPS_BUILDDIR}/${sourcepkg}-${version}/manual/graphics/logo.png usr/share/icons/hicolor/512x512/apps/odin2.png
		cd ${PKGDESTDIR}/usr/share/applications
		# generate desktop file
		gendesk -n \
		  --exec Odin2 \
		  --name Odin2 \
		  --pkgname odin2 \
		  --pkgdesc "${short_desc}" \
		  --icon odin2 \
		  --genericname "Virtual polyphonic synthesizer"
	}
}
