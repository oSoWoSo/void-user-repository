# Template file for 'odin2'
pkgname=odin2
version=2.4.1
revision=1
build_style=cmake
metapackage=yes
hostmakedepends="pkg-config"
makedepends="libX11-devel alsa-lib-devel MesaLib-devel libcurl-devel libwebkit2gtk41-devel lv2 gendesk"
depends="jack odin2-common odin2-lv2 odin2-clap odin2-vst3 odin2-standalone"
short_desc="24 voice polyphinic synthesizer with modulation and FX"
maintainer="Trve_AY <anthonyh@purplehaze.noho.st>"
license="GPL-3.0-only"
homepage="https://thewavewarden.com/pages/odin-2"
nocross=yes

