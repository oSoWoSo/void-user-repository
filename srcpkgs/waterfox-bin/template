# Template file for 'waterfox-bin'
pkgname=waterfox-bin
version=6.6.12
revision=1
archs="x86_64"
short_desc="Fast and private web browser"
maintainer="zenobit <zenobit@disroot.org>"
license="MPL-2.0"
homepage="https://www.waterfox.net"
changelog="https://www.waterfox.net/docs/releases/${version}/"
distfiles="https://cdn.waterfox.com/waterfox/releases/${version}/Linux_x86_64/waterfox-${version}.tar.bz2"
checksum=e261157aa1a23733b96aee0bb0e31ce62e94690fc0c55f571f579aec701dfa45
#nopie=yes

do_install() {
	vmkdir opt/waterfox
	vcopy * opt/waterfox
	vmkdir usr/bin
	ln -rfs opt/waterfox/waterfox "${DESTDIR}/usr/bin/waterfox"
	vinstall "${FILESDIR}/waterfox.desktop" 0644 usr/share/applications
	for res in 16 32 48 64 128; do
		vmkdir usr/share/icons/hicolor/${res}x${res}/apps
		ln -rfs "${DESTDIR}/opt/waterfox/browser/chrome/icons/default/default${res}.png" \
			"${DESTDIR}/usr/share/icons/hicolor/${res}x${res}/apps/waterfox.png"
	done
	vinstall "${FILESDIR}/vendor.js" 644 opt/waterfox/browser/defaults/preferences
	vinstall "${FILESDIR}/policies.json" 644 opt/waterfox/distribution
}
