# Template file for 'cosmic-initial-setup'
pkgname=cosmic-initial-setup
version=1.0.12
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
hostmakedepends="pkg-config just curl tar git-lfs git $(vopt_if sccache "rust-sccache")"
makedepends="eudev-libudev-devel libxkbcommon-devel openssl-devel flatpak-devel libinput-devel"
depends="pop-icons"
short_desc="COSMIC Initial Setup"
maintainer="Bella Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-initial-setup"
distfiles="https://github.com/pop-os/cosmic-initial-setup/archive/refs/tags/epoch-${version}.tar.gz"
checksum=72827c317cf58c7448c366590c1aed5fe4225cd928e8a6a1ee5ee3a5e74c9878
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
	export DISABLE_IF_EXISTS="/usr/bin/void-installer"
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
}
