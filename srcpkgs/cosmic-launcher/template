# Template file for 'cosmic-launcher'
pkgname=cosmic-launcher
version=1.0.11
revision=1
build_options="sccache"
build_style="cargo"
archs="x86_64* i686"
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel which"
depends="libxkbcommon pop-launcher"
short_desc="COSMIC App Launcher"
maintainer="Bella Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-launcher"
distfiles="https://github.com/pop-os/cosmic-launcher/archive/refs/tags/epoch-${version}.tar.gz"
checksum=30c5daa37c7a3312a0f269bc96fecd923c2c420d80b5f1a250365a1c8aee0977

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
}
