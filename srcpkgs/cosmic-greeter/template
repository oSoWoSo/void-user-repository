# Template file for 'cosmic-greeter'
pkgname=cosmic-greeter
version=1.0.12
revision=1
archs="x86_64* i686"
build_style=cargo
configure_args="--all"
hostmakedepends="pkg-config just $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel eudev-libudev-devel git git-lfs pam-devel libinput-devel llvm18-devel"
depends="greetd libxkbcommon pam-libs"
short_desc="COSMIC Display Manager"
maintainer="Bella Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-greeter"
distfiles="https://github.com/pop-os/cosmic-greeter/archive/refs/tags/epoch-${version}.tar.gz"
checksum=8a801c89bf97cbe50953aec43fcdf27e3f80558b34730fd75227854898758295
build_options="sccache"
#skip_extraction=yes

system_accounts="_cosmicgreeter"
_cosmicgreeter_homedir="/var/lib/cosmic-greeter"
_cosmicgreeter_descr="Cosmic Greeter Account"
_cosmicgreeter_groups="video"

export VERGEN_GIT_COMMIT_DATE="${version}_${revision}"
export VERGEN_GIT_SHA="${version}_${revision}"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
	vinstall cosmic-greeter.toml 644 etc/greetd
	vsv cosmic-greeter
	vinstall debian/cosmic-greeter.pam 644 /etc/pam.d/ cosmic-greeter
	vinstall dbus/com.system76.CosmicGreeter.conf 644 /usr/share/dbus-1/system.d
}
