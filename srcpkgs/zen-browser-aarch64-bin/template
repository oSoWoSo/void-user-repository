# Template file for 'zen-browser-aarch64-bin'
pkgname=zen-browser-aarch64-bin
version=1.19.13b
revision=1
archs="aarch64"
hostmakedepends="pkg-config"
depends="gtk+3 libstdc++  pango atk cairo gdk-pixbuf glib libxcb libX11 libXext
 libXrandr libXcomposite libXcursor libXdamage libXfixes libXi libXrender
 alsa-lib freetype fontconfig dbus-libs"
short_desc="New Browser based on Firefox"
maintainer="Bella Viola Wagner <belladev109@proton.me>"
license="MPL-2.0"
homepage="https://github.com/zen-browser/desktop"
distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-aarch64.tar.xz"
checksum=9e574c63f652f41c2a0f57b4803dc628f66a7f0a89469271abe1844896f039f2

do_install() {
	vmkdir usr/lib/zen-browser
	vcopy * usr/lib/zen-browser
	vmkdir usr/bin
	ln -s /usr/lib/zen-browser/zen ${DESTDIR}/usr/bin/
	vinstall ${FILESDIR}/zen-browser.desktop 644 usr/share/applications
	for size in 16 32 48 64 128; do
		cp browser/chrome/icons/default/default${size}.png browser/chrome/icons/default/zen-browser.png
		vinstall browser/chrome/icons/default/zen-browser.png 644 usr/share/icons/hicolor/${size}x${size}/apps
	done
}
