 https://github.com/EliverLara/Sweet-folders/archive/${_rainbow}.tar.gz"
checksum="2b940ccee268ea8c7a42f674f67a24d005c295b7ca61807a30d8a737f52ab4b8
 386f66922f9811e42a2b1e4018d5f43f759cb5d778c74345a1483d6c076402e5"

post_build() {
	#symlinks for ungoogled chromium
	cd candy-icons-${_candy}/apps/scalable
	ln -s chromium.svg ungoogled-chromium.svg
	ln -s chromium.svg ungoogled-chromium-browser.svg
	ln -s chromium.svg Ungoogled-Chromium.svg
	ln -s chromium.svg Ungoogled-Chromium-browser.svg
}

do_install() {
	vmkdir usr/share/icons
	vcopy candy-icons-${_candy} usr/share/icons/candy-icons
	for f in Sweet-folders-${_rainbow}/Sweet-* ; do
	vcopy $f usr/share/icons
	done
}
