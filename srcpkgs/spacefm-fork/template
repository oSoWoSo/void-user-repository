conflicts="spacefm"

pre_configure() {
	# Move spacefm source from extracted subdir into wrksrc
	mv spacefm-master/* ./ 2>/dev/null || true
	mv spacefm-master/.* ./ 2>/dev/null || true
	rm -rf spacefm-master

	# Setup ztd and glaze as meson subprojects
	rm -rf subprojects/ztd subprojects/glaze
	mv ztd-master subprojects/ztd
	mv glaze-main subprojects/glaze

	# Replace std::flat_map with std::map (GCC 14 lacks <flat_map>)
	find . \( -name "*.cxx" -o -name "*.hxx" \) -path "*/src/*" \
		-exec sed -i 's/std::flat_map/std::map/g; s/#include <flat_map>/#include <map>/g' {} +
}
