         const auto fields = ztd::split(line, " ");
-        if (fields.size() != 11)
+        // mountinfo has 6 fixed fields, 0+ optional fields, "-" separator, then 3 fields
+        // minimum is 10 tokens (0 optional fields)
+        if (fields.size() < 10)
+        {
+            logger::error<logger::vfs>("Invalid mountinfo entry: size={}, line={}",
+                                       fields.size(),
+                                       line);
+            continue;
+        }
+
+        // Find "-" separator starting after the 6 mandatory fields
+        const auto sep_it = std::find(fields.begin() + 6, fields.end(), std::string{"-"});
+        if (sep_it == fields.end() || std::distance(sep_it, fields.end()) < 4)
         {
             logger::error<logger::vfs>("Invalid mountinfo entry: size={}, line={}",
                                        fields.size(),
                                        line);
             continue;
         }
+        const auto sep_idx = static_cast<std::size_t>(std::distance(fields.begin(), sep_it));
 
