+template<typename To, typename From>
+constexpr enable_if_t<is_integral_v<To> && is_integral_v<From>, To>
+saturating_cast(const From v) noexcept {
+	if constexpr (is_unsigned_v<To> && is_unsigned_v<From>)
+		return v > numeric_limits<To>::max() ? numeric_limits<To>::max() : static_cast<To>(v);
+	else if constexpr (is_signed_v<To> && is_signed_v<From>)
+		return v < numeric_limits<To>::min() ? numeric_limits<To>::min() :
+			v > numeric_limits<To>::max() ? numeric_limits<To>::max() : static_cast<To>(v);
+	else if constexpr (is_signed_v<To> && is_unsigned_v<From>)
+		return v > static_cast<make_unsigned_t<To>>(numeric_limits<To>::max()) ?
+			numeric_limits<To>::max() : static_cast<To>(v);
+	else
+		return v < 0 ? 0 :
+			static_cast<make_unsigned_t<From>>(v) > numeric_limits<To>::max() ?
+			numeric_limits<To>::max() : static_cast<To>(v);
+}
+
+template<typename T>
+constexpr enable_if_t<is_integral_v<T>, T>
+saturating_add(const T a, const T b) noexcept {
+	if constexpr (is_unsigned_v<T>)
+		return a > numeric_limits<T>::max() - b ? numeric_limits<T>::max() : a + b;
+	else
+		return (b > 0 && a > numeric_limits<T>::max() - b) ? numeric_limits<T>::max() :
+			(b < 0 && a < numeric_limits<T>::min() - b) ? numeric_limits<T>::min() : a + b;
+}
+
+template<typename T>
+constexpr enable_if_t<is_integral_v<T>, T>
+saturating_sub(const T a, const T b) noexcept {
+	if constexpr (is_unsigned_v<T>)
+		return a < b ? 0 : a - b;
+	else
+		return (b < 0 && a > numeric_limits<T>::max() + b) ? numeric_limits<T>::max() :
+			(b > 0 && a < numeric_limits<T>::min() + b) ? numeric_limits<T>::min() : a - b;
+}
+
+template<typename T>
+constexpr enable_if_t<is_integral_v<T>, T>
+saturating_mul(const T a, const T b) noexcept {
+	if constexpr (is_unsigned_v<T>)
+		return b == 0 ? 0 :
+			a > numeric_limits<T>::max() / b ? numeric_limits<T>::max() : a * b;
+	else {
+		if (a == 0 || b == 0) return 0;
+		if (a > 0) {
+			if (b > 0)
+				return a > numeric_limits<T>::max() / b ? numeric_limits<T>::max() : a * b;
+			else
+				return b < numeric_limits<T>::min() / a ? numeric_limits<T>::min() : a * b;
+		} else {
+			if (b > 0)
+				return a < numeric_limits<T>::min() / b ? numeric_limits<T>::min() : a * b;
+			else
+				return -a > numeric_limits<T>::max() / -b ? numeric_limits<T>::max() : a * b;
+		}
+	}
+}
+
+template<typename T>
+constexpr enable_if_t<is_integral_v<T>, T>
+saturating_div(const T a, const T b) noexcept {
+	if constexpr (is_signed_v<T>)
+		if (a == numeric_limits<T>::min() && b == -1) return numeric_limits<T>::max();
+	return a / b;
+}
