# Template file for 'cosmic-osd'
pkgname=cosmic-osd
version=1.0.12
revision=1
archs="x86_64* i686"
build_style=cargo
hostmakedepends="pkg-config $(vopt_if sccache "rust-sccache")"
makedepends="libxkbcommon-devel pulseaudio-devel pipewire-devel clang17-devel
 eudev-libudev-devel libinput-devel just"
depends="dbus-libs eudev-libudev lame libpulseaudio libxkbcommon libpulseaudio
 libsndfile libxcb libasyncns libflac libvorbis libogg libmpg123 libXau libXdmcp
 opus"
short_desc="COSMIC OSD"
maintainer="Bella Wagner <belladev109@proton.me>"
license="GPL-3.0-only"
homepage="https://github.com/pop-os/cosmic-osd"
distfiles="https://github.com/pop-os/cosmic-osd/archive/refs/tags/epoch-${version}.tar.gz"
checksum=677d584be6039d462ab7d9046e89443b134a8e1b8a1804a8f67bf5c61f8e2125
build_options="sccache"

pre_build() {
	$(vopt_if sccache "export RUSTC_WRAPPER=/usr/bin/sccache")
}

do_install() {
	just rootdir="${DESTDIR}" cargo-target-dir="target/${RUST_TARGET}" install
}
