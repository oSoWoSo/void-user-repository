do_install() {
	rm -f etc/cron.daily/brave-browser
	vcopy "*" /

	for size in 16 24 32 48 64 128 256; do
		vmkdir usr/share/icons/hicolor/${size}x${size}/apps
		vmove opt/brave.com/brave/product_logo_${size}.png \
		   usr/share/icons/hicolor/${size}x${size}/apps/brave-browser.png
	done
}
