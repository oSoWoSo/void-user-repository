# Template file for 'brave-browser-arm-bin'
pkgname=brave-browser-arm-bin
version=1.90.122
revision=1
archs="aarch64"
hostmakedepends="rpmextract"
short_desc="One of the most private browsers built on top off Chromium project"
maintainer="zenobit <zenobit@disroot.org>"
license="MPL-2.0"
homepage="https://www.brave.com/"
changelog="https://raw.githubusercontent.com/brave/brave-browser/refs/heads/master/CHANGELOG_DESKTOP.md"
distfiles="https://github.com/brave/brave-browser/releases/download/v${version}/brave-browser-${version}-1.aarch64.rpm"
checksum=66b6783001733387006ef185ff30ac5cfd0a6c45afffdc5c5eb67eb50e55b409

do_install() {
	rm -f etc/cron.daily/brave-browser
	vcopy * /
	for size in 16 24 32 48 64 128 256; do
		vmkdir usr/share/icons/hicolor/${size}x${size}/apps
		vcopy opt/brave.com/brave/product_logo_${size}.png usr/share/icons/hicolor/${size}x${size}/apps/brave-browser.png
	done
}
