# Template file for 'vote'
pkgname=vote
version=0.90.1
revision=1
depends="gum-panel xtools"
checkdepends="clitest jq perl"
short_desc="XBPS package management helper for VoidLinux"
maintainer="zenobit <zenobit@disroot.org>"
license="AGPL-3.0-only"
homepage="https://codeberg.org/oSoWoSo/vote"
distfiles="https://codeberg.org/oSoWoSo/vote/archive/${version}.tar.gz"
checksum=fcaaa846a90af12dfe0774710c6bb822ff03ca6af41dfc9ce5d0183b40b47c02

do_check() {
	./run.sh -t
}

do_install() {
	vmkdir usr/share/vote
	vmkdir usr/share/icons
	vmkdir usr/share/applications

	vcopy etc usr/share/vote
	vcopy frontends usr/share/vote
	vcopy lang usr/share/vote
	vcopy lib usr/share/vote

	vcopy assets/vote.kdl usr/share/vote
	vcopy assets/vote.svg usr/share/icons
	vcopy assets/vote.desktop usr/share/applications
	vbin vote
	#vcompletion bash-completion/completions/vpm bash
}

post_install() {
	vlicense LICENSE.agpl
}
