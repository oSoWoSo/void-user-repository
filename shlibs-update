#!/bin/sh
#
# Apply shlibs_remove and shlibs_append patches to a void-packages shlibs file.
#
# Author: zenobit <zenobit@disroot.org>
# License: GPL-3.0-only

SCRIPT_DIR=$(cd -- "$(dirname -- "$0")" && pwd)

SHLIBS_FILE='void-packages/common/shlibs'
APPEND_FILE="${SCRIPT_DIR}/shlibs_append"
REMOVE_FILE="${SCRIPT_DIR}/shlibs_remove"

usage() {
	prog=${0##*/}
	cat <<-EOF
	Usage: $prog [options]

	Apply shlibs_remove and shlibs_append patches to a void-packages shlibs file.

	Options
	  -s <file>   shlibs file to patch       (default: ${SHLIBS_FILE})
	  -a <file>   entries to append          (default: shlibs_append next to this script)
	  -r <file>   entries to remove          (default: shlibs_remove next to this script)
	  -h          print this message and exit
	EOF
}

fatal() {
	echo '[FATAL]' "$@" >&2
	exit 1
}

remove_entries() {
	_shlibs=$1 _removefile=$2 _line=''
	echo '==> Removing shlibs entries'
	while IFS= read -r _line; do
		[ -z "$_line" ] && continue
		grep -vF "$_line" "$_shlibs" > "${_shlibs}.tmp" \
			&& mv "${_shlibs}.tmp" "$_shlibs"
		echo "   - $_line"
	done < "$_removefile"
}

append_entries() {
	_shlibs=$1 _appendfile=$2 _line=''
	echo '==> Adding shlibs entries'
	while IFS= read -r _line; do
		[ -z "$_line" ] && continue
		if ! grep -qF "$_line" "$_shlibs"; then
			echo "$_line" >> "$_shlibs"
			echo "   + $_line"
		fi
	done < "$_appendfile"
}

main() {
	_opt='' OPTIND=1 OPTARG=''
	while getopts 'hs:a:r:' _opt; do
		case "$_opt" in
			h) usage; return 0 ;;
			s) SHLIBS_FILE=$OPTARG ;;
			a) APPEND_FILE=$OPTARG ;;
			r) REMOVE_FILE=$OPTARG ;;
			*) usage >&2; return 1 ;;
		esac
	done
	shift "$((OPTIND - 1))"

	[ -f "$SHLIBS_FILE" ] || fatal "shlibs file not found: ${SHLIBS_FILE}"

	[ -f "$REMOVE_FILE" ] && remove_entries "$SHLIBS_FILE" "$REMOVE_FILE"
	[ -f "$APPEND_FILE" ] && append_entries "$SHLIBS_FILE" "$APPEND_FILE"
}

main "$@"
