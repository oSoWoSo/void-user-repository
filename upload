#!/usr/bin/env bash
#
# Upload built XBPS packages to the Surfer (WebDAV) repository,
# update repodata, and sign the index.
#
# Author: zenobit <zenobit@disroot.org>
# Date: 10, May, 2026
# License: GPL-3.0-only

SURFER_URL="https://repo.osowoso.org"
SIGNED_BY="zenobit <zenobit@disroot.org>"

usage() {
	local prog=${0##*/}
	cat <<-EOF
	Usage: $prog [options]

	Upload packages from BUILDDIR to the Surfer WebDAV repository.

	Required environment:
	  ARCH           Target architecture (x86_64, x86_64-musl, aarch64, aarch64-musl)
	  SURFER_TOKEN   WebDAV authentication token
	  PRIV_KEY       Private key (PEM) for repository signing

	Optional environment:
	  REMOVED        Space-separated list of removed package names
	  BUILDDIR       Directory with built packages (default: current dir)

	Options
	  -h   print this message and exit
	EOF
}

fatal() {
	echo '[FATAL]' "$@" >&2
	exit 1
}

fetch-remote-list() {
	curl -s -X PROPFIND "${1}/" \
		-H 'Depth: 1' \
		-u ":${SURFER_TOKEN}" 2>/dev/null \
		| grep -o '<D:href>[^<]*\.xbps</D:href>' \
		| sed 's|<D:href>||;s|</D:href>||;s|.*/||' || true
}

delete-remote() {
	curl -s -X DELETE "${1}" -u ":${SURFER_TOKEN}" || true
}

upload-file() {
	local file="$1" dest="$2"
	echo "  Uploading: $(basename "$file")"
	curl -s -T "$file" "$dest" -u ":${SURFER_TOKEN}" \
		|| echo "  Warning: failed to upload $(basename "$file")"
}

pkg-name() {
	local without_arch="${1%.*}"
	local ver
	ver=$(printf '%s' "$without_arch" | sed 's/^.*-\([0-9][^-]*\)$/\1/')
	printf '%s' "${without_arch%-${ver}}"
}

# Generate arch index.html from actual xbps repodata (not templates).
# Only packages present in the repo are shown; metadata from srcpkgs templates.
build-arch-page() {
	local arch="$1" work_dir="$2"
	local out_dir="${script_dir}/docs/${arch}"
	local out="${out_dir}/index.html"
	local template="${script_dir}/.github/arch-index-template.html"
	local repo_url="${SURFER_URL}/${arch}"

	[[ -f $template ]] || { echo "  Warning: arch-index-template.html not found, skipping arch page"; return 1; }
	mkdir -p "$out_dir"

	local nav_tmp pkg_tmp svg_tmp
	nav_tmp=$(mktemp); pkg_tmp=$(mktemp); svg_tmp=$(mktemp)
	trap 'rm -f "$nav_tmp" "$pkg_tmp" "$svg_tmp"' RETURN

	local arch_names=("x86_64" "x86_64-musl" "aarch64" "aarch64-musl")
	for j in "${!arch_names[@]}"; do
		if [[ "${arch_names[$j]}" == "$arch" ]]; then
			printf '  <li><a href="." class="active">%s</a></li>\n' "$arch" >> "$nav_tmp"
		else
			printf '  <li><a href="../%s/">%s</a></li>\n' "${arch_names[$j]}" "${arch_names[$j]}" >> "$nav_tmp"
		fi
	done

	{
		printf '<table>\n<thead><tr>\n'
		printf '  <th>package</th><th>version</th><th>homepage</th><th>maintainer</th><th>description</th>\n'
		printf '</tr></thead>\n<tbody>\n'

		local pkg_count=0
		while IFS= read -r line; do
			# xbps-query -s output: "[*] pkgver short description"
			[[ $line =~ ^\[.\]\ ([^ ]+)\ (.+)$ ]] || continue
			local pkgver="${BASH_REMATCH[1]}"
			local short_desc="${BASH_REMATCH[2]}"

			# Extract pkgname: strip -version_revision suffix (version starts with digit)
			local pkgname
			pkgname=$(printf '%s' "$pkgver" | sed 's/-[0-9].*$//')

			# Only main packages (skip subpackages like libfoo-devel)
			local tpl="${script_dir}/srcpkgs/${pkgname}/template"
			[[ -f $tpl ]] || continue
			local dir_pkgname
			dir_pkgname=$(grep "^pkgname=" "$tpl" | head -1 | cut -d= -f2- | tr -d '"')
			[[ $dir_pkgname == "$pkgname" ]] || continue

			# Version from actual repo pkgver (strip revision suffix _N)
			local ver="${pkgver#${pkgname}-}"
			local version="${ver%_*}"

			local homepage maintainer
			homepage=$(grep "^homepage=" "$tpl" | head -1 | cut -d= -f2- | tr -d '"')
			maintainer=$(grep "^maintainer=" "$tpl" | head -1 | cut -d= -f2- | sed 's/ <.*//' | tr -d '"')

			printf '<tr><td><strong>%s</strong></td><td>%s</td><td><a href="%s">%s</a></td><td>%s</td><td>%s</td></tr>\n' \
				"$pkgname" "$version" "$homepage" "$homepage" "$maintainer" "$short_desc"
			pkg_count=$((pkg_count + 1))
		done < <(XBPS_ARCH="$arch" xbps-query --repository="$work_dir" -Rs "*" 2>/dev/null | sort)

		printf '</tbody>\n</table>\n'
	} > "$pkg_tmp"

	cp "${script_dir}/src/svg-color.html" "$svg_tmp" 2>/dev/null || touch "$svg_tmp"

	sed \
		-e "s|__ARCH__|${arch}|g" \
		-e "s|__CSS_URL__|../style.css|g" \
		-e "s|__HOME_URL__|../index.html|g" \
		-e "s|__REPO_URL__|${repo_url}|g" \
		-e "s|__GIT_CI_URL__|${REPO_URL:-${SURFER_URL}}|g" \
		-e 's|__FAVICON__|<link rel="icon" href="../favicon.ico" />|g' \
		"$template" \
	| awk \
		-v nav="$nav_tmp" \
		-v tbl="$pkg_tmp" \
		-v svg="$svg_tmp" \
		'/__NAV_ARCH_LINKS__/ { while ((getline ln < nav) > 0) print ln; close(nav); next }
		 /__PACKAGE_TABLE__/  { while ((getline ln < tbl) > 0) print ln; close(tbl); next }
		 /__SVGCOLOR__/       { while ((getline ln < svg) > 0) print ln; close(svg); next }
		 { print }' \
	> "$out"

	echo "  Generated ($pkg_count packages): $out"
}

main() {
	local script_dir opt OPTIND OPTARG
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	while getopts 'h' opt; do
		case "$opt" in
			h) usage; return 0;;
			*) usage >&2; return 1;;
		esac
	done
	shift "$((OPTIND - 1))"

	[[ -n $ARCH ]]         || fatal 'ARCH is required'
	[[ -n $SURFER_TOKEN ]] || fatal 'SURFER_TOKEN is required'
	[[ -n $PRIV_KEY ]]     || fatal 'PRIV_KEY is required'

	local builddir="${BUILDDIR:-$(pwd)}"
	local webdav="${SURFER_URL}/_webdav/${ARCH}"

	if ! ls "${builddir}"/*.xbps 1>/dev/null 2>&1; then
		echo '⚠️  No packages to upload'
		return 0
	fi

	local work_dir
	work_dir=$(mktemp -d)
	trap 'rm -rf "$work_dir"' EXIT

	# Ensure remote arch directory exists
	curl -s -X MKCOL "${webdav}/" -u ":${SURFER_TOKEN}" || true

	# Fetch remote file list for old-version cleanup
	echo '==> Fetching remote package list'
	local remote_list
	remote_list=$(fetch-remote-list "$webdav")

	cd "$work_dir" || fatal "Cannot cd to $work_dir"

	# Download repodata
	echo '==> Downloading repodata'
	curl -sf -o "${ARCH}-repodata" "${SURFER_URL}/${ARCH}/${ARCH}-repodata" \
		-u ":${SURFER_TOKEN}" 2>/dev/null || true

	# Copy new packages to work dir
	cp "${builddir}"/*.xbps . 2>/dev/null || true
	cp "${builddir}"/*.xbps.sig2 . 2>/dev/null || true

	# Delete old versions of updated packages from remote
	echo '==> Cleaning old package versions from remote'
	local new_pkg new_basename old_pkg name
	for new_pkg in "${builddir}"/*.xbps; do
		[[ -f $new_pkg ]] || continue
		new_basename=$(basename "$new_pkg")
		name=$(pkg-name "${new_basename%.xbps}")

		while IFS= read -r old_pkg; do
			[[ $old_pkg == "$new_basename" ]] && continue
			echo "  Deleting old: $old_pkg"
			delete-remote "${webdav}/${old_pkg}"
			delete-remote "${webdav}/${old_pkg}.sig2"
		done < <(printf '%s\n' $remote_list | grep "^${name}-[0-9]")
	done

	# Remove packages for deleted templates
	if [[ -n $REMOVED ]]; then
		echo "==> Removing packages for deleted templates: $REMOVED"
		local pkg
		for pkg in $REMOVED; do
			while IFS= read -r old_pkg; do
				echo "  Removing: $old_pkg"
				if curl -sf -o "$old_pkg" "${SURFER_URL}/${ARCH}/${old_pkg}" \
						-u ":${SURFER_TOKEN}" 2>/dev/null; then
					xbps-rindex -r . "$old_pkg" || true
					rm -f "$old_pkg" "${old_pkg}.sig2"
				fi
				delete-remote "${webdav}/${old_pkg}"
				delete-remote "${webdav}/${old_pkg}.sig2"
			done < <(printf '%s\n' $remote_list | grep "^${pkg}-[0-9]")
		done
	fi

	# Update and sign repository index
	echo '==> Updating repository index'
	xbps-rindex -a ./*.xbps 2>/dev/null || true

	echo '==> Signing repository'
	printf '%s\n' "$PRIV_KEY" > private.pem
	chmod 600 private.pem
	xbps-rindex -s --signedby "$SIGNED_BY" --privkey private.pem "$PWD"
	rm -f private.pem

	# Upload packages, signatures, and repodata
	echo '==> Uploading to Surfer'
	local file fname
	for file in ./*.xbps ./*.xbps.sig2 ./*-repodata; do
		[[ -f $file ]] || continue
		fname=$(basename "$file")
		upload-file "$file" "${webdav}/${fname}"
	done

	# Regenerate and upload arch info page from actual repo contents
	echo '==> Updating arch page'
	build-arch-page "$ARCH" "$work_dir"
	local arch_page="${script_dir}/docs/${ARCH}/index.html"
	if [[ -f $arch_page ]]; then
		upload-file "$arch_page" "${webdav}/index.html"
	else
		echo "  Warning: docs/${ARCH}/index.html not found"
	fi

	echo "==> Done: ${SURFER_URL}/${ARCH}/"
}

main "$@"
